rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== 개발/테스트용 규칙 =====
    // 모든 읽기/쓰기 허용 (임시)
    // ⚠️ 주의: Firebase Console에서도 동일하게 설정 필요
    match /{document=**} {
      allow read, write: if true;
    }
    
  }
}

// ===== 프로덕션 환경용 규칙 (나중에 적용) =====
