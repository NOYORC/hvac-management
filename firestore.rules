rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 임시 규칙 - Firebase Authentication 구현 전까지 사용
    // 경고: 프로덕션 환경에서는 사용하지 마세요!
    match /{document=**} {
      allow read, write: if true;
    }
    
    // TODO: Firebase Authentication 구현 후 아래 규칙으로 교체
